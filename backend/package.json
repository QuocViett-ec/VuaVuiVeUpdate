{
  "name": "vuavuive-backend",
  "version": "1.0.0",
  "description": "Backend API cho Vựa Vui Vẻ - Node.js + Express + MongoDB",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:plain": "node server.js",
    "seed": "node scripts/seed.js && node scripts/seed-orders.js",
    "seed:reviews": "node scripts/seed-reviews.js",
    "seed:ml-events": "node scripts/seed-ml-events.js",
    "smoke:recommender": "node scripts/smoke-recommender-test.js",
    "test": "jest",
    "test:payment": "jest tests/payment.test.js --no-coverage"
