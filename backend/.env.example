# ─── MongoDB ────────────────────────────────────────────────────────────────
# Dùng MongoDB Atlas (thay bằng connection string thực của bạn):
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/vuavuive?retryWrites=true&w=majority

# Hoặc MongoDB local:
# MONGO_URI=mongodb://localhost:27017/vuavuive

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Session ────────────────────────────────────────────────────────────────
SESSION_SECRET=vvv_super_secret_session_key_2026
SESSION_MAX_AGE_MS=604800000

# ─── CORS ───────────────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:4200

# ─── ML Recommender API ─────────────────────────────────────────────────────
# Production example: https://vuavuive-ml.onrender.com
RECOMMENDER_API=https://vuavuive-ml.onrender.com

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Lấy từ Google Cloud Console → APIs & Services → Credentials
# https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ─── Email SMTP (Password Reset OTP) ────────────────────────────────────────
RESEND_API_KEY=your_resend_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM=noreply@vuavuive.vn
PASSWORD_RESET_OTP_TTL_MINUTES=10
PASSWORD_RESET_TOKEN_TTL_MINUTES=15

# ─── VNPay Sandbox (TEST ONLY) ─────────────────────────────────────────────
VNP_TMN_CODE=TFQUUGXU
VNP_HASH_SECRET=6CWJ6YCV87XZR9J3L6VUYRLZ93UHXEXK
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURN_URL=http://localhost:4200/checkout/return
BACKEND_PUBLIC_URL=http://localhost:3000
CUSTOMER_PORTAL_BASE=http://localhost:4200
ADMIN_PORTAL_BASE=http://localhost:4201
# Production: thay bằng mã thật từ https://sandbox.vnpayment.vn

# ─── MoMo Test (TEST ONLY) ─────────────────────────────────────────────────
MOMO_PARTNER_CODE=your_momo_partner_code
MOMO_ACCESS_KEY=your_momo_access_key
MOMO_SECRET_KEY=your_momo_secret_key
