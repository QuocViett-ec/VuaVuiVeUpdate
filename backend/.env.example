MOMO_REQUEST_TYPE=payWithMethod
MOMO_REDIRECT_URL=http://localhost:4200/checkout/momo-return
MOMO_IPN_URL=https://your-public-domain-or-ngrok/api/payment/momo/ipn
# Production: thay bằng Partner Code, Access Key, Secret Key thật từ https://developers.momo.vn
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_TIMEOUT_MS=12000
