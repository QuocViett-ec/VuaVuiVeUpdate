# ─── MongoDB ────────────────────────────────────────────────────────────────
# Dùng MongoDB Atlas (thay bằng connection string thực của bạn):
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/vuavuive?retryWrites=true&w=majority

# Hoặc MongoDB local:
# MONGO_URI=mongodb://localhost:27017/vuavuive

# ─── Server ─────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Session ────────────────────────────────────────────────────────────────
SESSION_SECRET=vvv_super_secret_session_key_2026
SESSION_MAX_AGE_MS=604800000

# ─── CORS ───────────────────────────────────────────────────────────────────
CLIENT_ORIGIN=http://localhost:4200

# ─── ML Recommender API ─────────────────────────────────────────────────────
RECOMMENDER_API=http://localhost:5001

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Lấy từ Google Cloud Console → APIs & Services → Credentials
# https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

